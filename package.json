{
  "name": "dbs-project-management",
  "version": "1.0.0",
  "private": true,
  "description": "DBS Department Project & Budget Management Platform",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "npm run dev --prefix apps/web",
    "build": "cd apps/web && npm run build",
    "start": "cd apps/web && npm run start",
    "db:push": "npm run db:push --prefix apps/web",
    "db:seed": "npm run db:seed --prefix apps/web",
    "db:deploy": "cd apps/web && npm run db:deploy",
    "db:studio": "npm run db:studio --prefix apps/web"
  }
}
