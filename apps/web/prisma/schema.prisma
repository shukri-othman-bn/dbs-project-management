generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DIRECTOR
  HOS
  OFFICER
  ADMIN
  PROJECT_ADMIN
}

enum LifecycleStage {
  pre_design
  design
  quotation_tender
  ongoing
  completed
  keep_in_view
}

enum ProjectType {
  quotations
  contract_works
  consultancy
  maintenance
  bca
  other
}

enum ContractCategory {
  one_off_project
  fsor
}

enum BudgetLineType {
  warrant
  encumbrance
  payment
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(OFFICER)
  sectionId    String?
  section      Section?  @relation(fields: [sectionId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[] @relation("ProjectOic")
}

model Section {
  id        String          @id @default(cuid())
  name      String          @unique
  code      String?         @unique
  unitLabel String?
  headName  String?
  headEmail String?
  users     User[]
  projects  Project[]
  budgets   SectionBudget[]
  matterRequests MatterRequest[]
  createdAt DateTime        @default(now())
}

model SectionBudget {
  id              String        @id @default(cuid())
  sectionId       String
  section         Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  financialYearId String
  financialYear   FinancialYear @relation(fields: [financialYearId], references: [id])
  allocation      Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([sectionId, financialYearId])
}

model FinancialYear {
  id             String          @id @default(cuid())
  label          String          @unique
  startDate      DateTime
  endDate        DateTime
  isCurrent      Boolean         @default(false)
  budgets        ProjectBudget[]
  sectionBudgets SectionBudget[]
  fundingTypeBudgets FundingTypeBudget[]
  createdAt      DateTime        @default(now())
}

model FundingType {
  id           String              @id @default(cuid())
  name         String              @unique
  mainCategory String?
  projects     Project[]
  budgets      FundingTypeBudget[]
  createdAt    DateTime            @default(now())
}

model FundingTypeBudget {
  id                  String        @id @default(cuid())
  fundingTypeId       String
  fundingType         FundingType   @relation(fields: [fundingTypeId], references: [id], onDelete: Cascade)
  financialYearId     String
  financialYear       FinancialYear @relation(fields: [financialYearId], references: [id])
  allocation          Float         @default(0)
  encumbranceTotal    Float         @default(0)
  encumbranceBalance  Float         @default(0)
  budgetSummaryLocked Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([fundingTypeId, financialYearId])
}

model Client {
  id         String    @id @default(cuid())
  ministry   String
  department String?
  projects   Project[]
  createdAt  DateTime  @default(now())

  @@unique([ministry, department])
}

model Project {
  id                    String           @id @default(cuid())
  projectNumber         String           @unique
  title                 String
  lifecycleStage        LifecycleStage   @default(pre_design)
  projectType           ProjectType?
  contractCategory      ContractCategory?
  quotationOrContractNo String?
  internalProjectNo     String?
  toMonitor             Boolean          @default(false)
  team                  String?
  contractorName        String?
  sectionId             String?
  section               Section?         @relation(fields: [sectionId], references: [id])
  clientId              String?
  client                Client?          @relation(fields: [clientId], references: [id])
  fundingTypeId         String?
  fundingType           FundingType?     @relation(fields: [fundingTypeId], references: [id])
  oicUserId             String?
  oic                   User?            @relation("ProjectOic", fields: [oicUserId], references: [id])
  oicName               String?
  oicEmail              String?
  design                ProjectDesign?
  bca                   ProjectBca?
  feasibility           ProjectFeasibility?
  tendering             ProjectTendering?
  contract              ContractDetails?
  fsorConfig            ProjectFsorConfig?
  completion            ProjectCompletion?
  documents             ProjectDocuments?
  statusUpdates         StatusUpdate[]
  budgets               ProjectBudget[]
  budgetLines           BudgetLine[]
  variationOrders       VariationOrder[]
  extensionOfTimes      ExtensionOfTime[]
  jobOrders             JobOrder[]
  purchaseOrders        PurchaseOrder[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

model ProjectDesign {
  id                         String    @id @default(cuid())
  projectId                  String    @unique
  project                    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  preliminaryEstimate        Float?
  designProjectNo            String?
  designProgressAsOf         DateTime?
  svAmount                   Float?
  dateDrawingsCompleted      DateTime?
  dateMeBqReceived           DateTime?
  dateBqCompleted            DateTime?
  dateOtherDocumentsReceived DateTime?
  dateConfirmed              DateTime?
  quotationTenderDueDate     DateTime?
  actualQuotationTenderDate  DateTime?
  remarks                    String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
}

model ProjectBca {
  id            String    @id @default(cuid())
  projectId     String    @unique
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dateAssigned  DateTime?
  dateDue       DateTime?
  dateCompleted DateTime?
  estimate      Float?
  letterDate    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ProjectFeasibility {
  id                String    @id @default(cuid())
  projectId         String    @unique
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestDate       DateTime?
  siteInspection    DateTime?
  estimate          Float?
  proposedPeriod    String?
  estimateSubmitted DateTime?
  dateClientConfirm DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model ProjectTendering {
  id                         String    @id @default(cuid())
  projectId                  String    @unique
  project                    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenderNo                   String?
  completionPeriod           String?
  openDate                   DateTime?
  closingDate                DateTime?
  extendedClosingDate        DateTime?
  receivedDate               DateTime?
  assessmentSubmittedDate    DateTime?
  recommendationDate         DateTime?
  recommendationFromDbsoDate DateTime?
  awardedDate                DateTime?
  approvedDate               DateTime?
  loaDate                    DateTime?
  startDateInLoa             DateTime?
  completeDateInLoa          DateTime?
  adRemarks                  String?
  tenderValidityRemarks      String?
  latestQuotationValidityDate DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
}

model ContractDetails {
  id                    String    @id @default(cuid())
  projectId             String    @unique
  project               Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mainContractor        String?
  contractNo            String?
  contractSum           Float?
  revisedContractSum    Float?
  contractPeriod        String?
  contractStart         DateTime?
  contractFinish        DateTime?
  revisedContractFinish DateTime?
  sitePossessionDate    DateTime?
  loaIssued             DateTime?
  bgStartDate           DateTime?
  bgExpiry              DateTime?
  insuranceStartDate    DateTime?
  insuranceExpiry       DateTime?
  cncDate               DateTime?
  performanceBondExpiry DateTime?
  contractSigned        DateTime?
  cpcDate               DateTime?
  cpcIssued             DateTime?
  edlp                  DateTime?
  revisedEdlpDate       DateTime?
  cmgdIssuedDate        DateTime?
  finalAccountSum       Float?
  retentionSum          Float?
  remarks               String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model ProjectFsorConfig {
  id                String    @id @default(cuid())
  projectId         String    @unique
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  defaultBidPercent Float     @default(5)
  pwdNo             String?
  others            String?
  soiRef            String?
  signatoryName     String?
  signatoryTitle    String?
  scopeDescription  String?
  buildings         String[]
  lastSyncedAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model ProjectCompletion {
  id                  String    @id @default(cuid())
  projectId           String    @unique
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  physicalActual      Float?
  physicalScheduled   Float?
  paymentActual       Float?
  paymentScheduled    Float?
  progressAsOf        DateTime?
  completionDate      DateTime?
  defectsLiabilityEnd DateTime?
  finalAccountDate    DateTime?
  remarks             String?
  actionsRequired     String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model ProjectDocuments {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  otherDocumentNotes  String?
  submissionNotes     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model StatusUpdate {
  id                String   @id @default(cuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  progressAsOf      DateTime
  physicalActual    Float    @default(0)
  physicalScheduled Float    @default(0)
  paymentActual     Float    @default(0)
  paymentScheduled  Float    @default(0)
  remarks           String?
  actionsRequired   String?
  createdById       String?
  createdAt         DateTime @default(now())
}

model ProjectBudget {
  id                 String        @id @default(cuid())
  projectId          String
  project            Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  financialYearId    String
  financialYear      FinancialYear @relation(fields: [financialYearId], references: [id])
  allocation         Float         @default(0)
  encumbranceTotal   Float         @default(0)
  encumbranceBalance Float         @default(0)
  budgetSummaryLocked Boolean      @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([projectId, financialYearId])
}

model BudgetLine {
  id                   String          @id @default(cuid())
  projectId            String
  project              Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  financialYearId      String?
  fsorJoId             String?         @unique
  type                 BudgetLineType
  date                 DateTime?
  claimDate            DateTime?
  description          String?
  progressClaimNo      Int?
  amountApproved       Float           @default(0)
  amountCertified      Float?
  amountBalance        Float?
  voucherRef           String?
  createdAt            DateTime        @default(now())
  purchaseOrder        PurchaseOrder?
  warrantPurchaseOrders PurchaseOrder[] @relation("WarrantPurchaseOrders")
}

model VariationOrder {
  id                    String    @id @default(cuid())
  projectId             String
  project               Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submittedToSbmDate    DateTime?
  receivedByDbsoDate    DateTime?
  committeeReviewDate     DateTime?
  submittedToDgoDate    DateTime?
  submittedToClientDate DateTime?
  approvedDate          DateTime?
  voAmount              Float?
  voPercent             Float?
  revisedContractSum    Float?
  isLocked              Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model ExtensionOfTime {
  id                    String    @id @default(cuid())
  projectId             String
  project               Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submittedToSbmDate    DateTime?
  receivedByDbsoDate    DateTime?
  committeeReviewDate   DateTime?
  submittedToDgoDate    DateTime?
  submittedToClientDate DateTime?
  approvedDate          DateTime?
  eotPeriod             String?
  eotPercent            Float?
  revisedCompletionDate DateTime?
  isLocked              Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model JobOrder {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fsorJoId        String?   @unique
  fsorStatus      String?
  fsorSyncedAt    DateTime?
  joNo            String?
  joAmount        Float     @default(0)
  fsorPercent     Float?
  joStart         DateTime?
  actualJoFinish  DateTime?
  joEdlpDue       DateTime?
  cmgdIssued      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model PurchaseOrder {
  id              String      @id @default(cuid())
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetLineId    String?     @unique
  budgetLine      BudgetLine? @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)
  warrantLineId   String?
  warrantLine     BudgetLine? @relation("WarrantPurchaseOrders", fields: [warrantLineId], references: [id], onDelete: SetNull)
  poId            String?
  claimDate       DateTime?
  claimCertified  Float?
  poAmount        Float       @default(0)
  sesDate         DateTime?
  invoiceDate     DateTime?
  eDispatchedDate DateTime?
  eDispatchRef    String?
  paidDate        DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model MatterRequest {
  id                String    @id @default(cuid())
  sectionId         String?
  section           Section?  @relation(fields: [sectionId], references: [id])
  ticketNo          String?
  complainant       String?
  contactNo         String?
  address           String?
  complaintReceived DateTime?
  receivedMethod    String?
  typeOfComplaint   String?
  status            String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
