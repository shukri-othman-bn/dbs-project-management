# PostgreSQL (local Docker example — see docs/DEPLOY-DIGITALOCEAN.md)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dbs"
# DigitalOcean production: set DATABASE_URL=${dbs-db.DATABASE_URL} in App Platform

AUTH_SECRET="generate-a-secure-random-string"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# FSOR app integration (local serve.ps1 defaults)
# Local FSOR (serve.ps1 or npm start)
FSOR_SYNC_URL="http://127.0.0.1:8765/api/v1"
FSOR_APP_URL="http://127.0.0.1:8765"

# Production (Railway FSOR service — uncomment and set your domain)
# FSOR_SYNC_URL="https://<your-fsor-domain>/api/v1"
# FSOR_APP_URL="https://<your-fsor-domain>"
